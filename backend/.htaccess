<IfModule mod_rewrite.c>
    RewriteEngine On
    # Catch ALL OPTIONS preflight requests before they hit Node.js
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L,E=IS_OPTIONS:1,E=HTTP_ORIGIN:%{HTTP:ORIGIN}]
</IfModule>

<IfModule mod_headers.c>
    # ONLY add these headers to the OPTIONS response, relying on Node.js cors() for the rest
    Header always set Access-Control-Allow-Origin "%{HTTP_ORIGIN}e" env=IS_OPTIONS
    Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS, DELETE, PUT" env=IS_OPTIONS
    Header always set Access-Control-Max-Age "1000" env=IS_OPTIONS
    Header always set Access-Control-Allow-Headers "x-requested-with, Content-Type, origin, authorization, accept, client-security-token" env=IS_OPTIONS
    Header always set Access-Control-Allow-Credentials "true" env=IS_OPTIONS
</IfModule>
